{
  "name": "@ball-knowledge/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --conditions development --env-file-if-exists=.env.local src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "smoke": "TOTAL_ROUNDS=2 COUNTDOWN_MS=400 ROUND_MS=2500 node scripts/smoke.mjs"
  },
  "dependencies": {
    "@ball-knowledge/shared": "*",
    "jose": "^6.2.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "20.19.43",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.3",
    "typescript": "5.9.3"
  }
}
