# Copy to `.env` on the Hetzner server and fill in. Used by docker-compose.yml.
# Do NOT commit the real .env (it's gitignored).

# Public domain for the backend, with a DNS A/AAAA record pointing at this box.
# Caddy gets a TLS cert for it; the client connects to wss://<this>.
DOMAIN=api.yourdomain.com

# Email for Let's Encrypt expiry notices (recommended, can be left blank).
ACME_EMAIL=you@example.com

# Supabase project URL (no trailing slash). The server fetches this project's
# JWKS to verify player access tokens. Must be the SAME project the client uses.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# JWT audience claim to require. Supabase default is "authenticated".
SUPABASE_JWT_AUD=authenticated
